from common_utils import panic
from collections import List
from memory import Pointer


struct IntArray(ImplicitlyCopyable, Representable, Sized, Stringable, Writable):
    """A lightweight, register-passable growable array of integers.
    Uses List[Int] internally for memory management.
    """

    var _list: List[Int]  # Internal List storage

    # ========== Construction ==========

    @always_inline("nodebug")
    fn __init__(out self):
        """Create empty array."""
        self._list = List[Int]()

    @always_inline("nodebug")
    fn __init__(out self, *values: Int):
        """Create from variadic args: IntArray(1, 2, 3)."""
        self._list = List[Int](capacity=len(values))
        for i in range(len(values)):
            self._list.append(values[i])

    @always_inline("nodebug")
    fn __init__(out self, values: VariadicList[Int]):
        """Create from VariadicList: IntArray(1, 2, 3)."""
        var n = len(values)
        self._list = List[Int](capacity=n)
        for i in range(n):
            self._list.append(values[i])

    @always_inline("nodebug")
    fn __init__(out self, values: List[Int]):
        """Create from List[Int]."""
        self._list = values.copy()

    @always_inline("nodebug")
    fn __copyinit__(out self, existing: Self):
        """Deep copy."""
        self._list = existing._list.copy()

    @always_inline("nodebug")
    fn __del__(deinit self):
        """Free memory - handled by List's destructor."""
        pass

    # ========== Static Constructors ==========

    @staticmethod
    @always_inline("nodebug")
    fn filled(size: Int, value: Int) -> Self:
        """Create array filled with value."""
        var result = IntArray()
        result._list = List[Int](capacity=size)
        for _ in range(size):
            result._list.append(value)
        return result^

    @staticmethod
    @always_inline("nodebug")
    fn range(start: Int, end: Int, step: Int = 1) -> Self:
        """Create from range."""
        if step == 0:
            panic("IntArray.range: step cannot be zero")

        var result = IntArray()
        if step > 0:
            var val = start
            while val < end:
                result.append(val)
                val += step
        else:
            var val = start
            while val > end:
                result.append(val)
                val += step
        return result^

    @staticmethod
    @always_inline("nodebug")
    fn with_capacity(capacity: Int) -> Self:
        """Create with capacity but zero size."""
        var result = Self()
        result._list = List[Int](capacity=capacity)
        return result^

    @staticmethod
    @always_inline
    fn invert_permutation(perm: Self) -> Self:
        """Invert a permutation."""
        var inverted = IntArray.filled(len(perm), 0)
        for i in range(len(perm)):
            inverted[perm[i]] = i
        return inverted^

    # ========== Properties ==========

    @always_inline("nodebug")
    fn size(self) -> Int:
        """Number of elements."""
        return len(self._list)

    @always_inline("nodebug")
    fn __len__(self) -> Int:
        """Number of elements."""
        return len(self._list)

    @always_inline("nodebug")
    fn capacity(self) -> Int:
        """Allocated capacity."""
        return self._list.capacity

    @always_inline("nodebug")
    fn is_empty(self) -> Bool:
        """Check if empty."""
        return len(self._list) == 0

    # ========== Access ==========

    @always_inline("nodebug")
    fn __getitem__(self, idx: Int) -> Int:
        """Get element at index (supports negative indexing)."""
        var index = idx if idx >= 0 else idx + len(self._list)
        if index < 0 or index >= len(self._list):
            panic("IntArray: index out of bounds")
        return self._list[index]

    @always_inline("nodebug")
    fn __setitem__(mut self, idx: Int, value: Int):
        """Set element at index (supports negative indexing)."""
        var index = idx if idx >= 0 else idx + len(self._list)
        if index < 0 or index >= len(self._list):
            panic("IntArray: index out of bounds")
        self._list[index] = value

    @always_inline("nodebug")
    fn __getitem__(self, slice: Slice) -> Self:
        """Get slice as new array."""
        var step = slice.step.or_else(1)

        if step == 0:
            panic("IntArray: slice step cannot be zero")

        # Handle start and stop based on step direction
        var start: Int
        var stop: Int

        if step > 0:
            start = slice.start.or_else(0)
            stop = slice.end.or_else(len(self._list))
        else:  # step < 0
            start = slice.start.or_else(len(self._list) - 1)
            stop = slice.end.or_else(-len(self._list) - 1)

        # Normalize negative indices
        if start < 0:
            start += len(self._list)
        if stop < 0:
            stop += len(self._list)

        # Calculate size based on step direction
        var size: Int
        if step > 0:
            size = max(0, (stop - start + step - 1) // step)
        else:
            size = max(0, (start - stop - step - 1) // (-step))

        var result = IntArray.with_capacity(size)
        var src_idx = start

        if step > 0:
            while src_idx < stop and src_idx < len(self._list):
                if src_idx >= 0:
                    result.append(self._list[src_idx])
                src_idx += step
        else:
            while src_idx > stop and src_idx >= 0:
                if src_idx < len(self._list):
                    result.append(self._list[src_idx])
                src_idx += step

        return result^

    # ========== Growth Operations ==========

    @always_inline("nodebug")
    fn reserve(mut self, required: Int):
        """Ensure capacity, reallocating if needed."""
        self._list.reserve(required)

    @always_inline
    fn append(mut self, value: Int):
        """Append element."""
        self._list.append(value)

    @always_inline
    fn prepend(mut self, value: Int):
        """Prepend element."""
        # Note: List doesn't have prepend, so we implement it manually
        var new_list = List[Int](capacity=len(self._list) + 1)
        new_list.append(value)
        for i in range(len(self._list)):
            new_list.append(self._list[i])
        self._list = new_list^

    @always_inline("nodebug")
    fn __iadd__(mut self, other: Self):
        """Inplace add with other."""
        if len(self) != len(other):
            panic("IntArray -> __iadd__(other): unequal lengths")
        for i in range(len(self)):
            self[i] += other[i]

    @always_inline("nodebug")
    fn __iadd__(mut self, other: List[Int]):
        """Inplace add with other list."""
        if len(self) != len(other):
            panic("IntArray -> __iadd__(other[List]): unequal lengths")
        for i in range(len(self)):
            self[i] += other[i]

    @always_inline("nodebug")
    fn __radd__(self, value: Int) -> Self:
        return IntArray(value).__add__(self)

    @always_inline("nodebug")
    fn __add__(self, value: Int) -> Self:
        """Return new array with value added."""
        var result = IntArray.with_capacity(len(self._list) + 1)
        for i in range(len(self._list)):
            result.append(self._list[i])
        result.append(value)
        return result^

    @always_inline("nodebug")
    fn __add__(self, other: IntArray) -> Self:
        """Return new array with values of other IntArray added."""
        var result = IntArray.with_capacity(len(self._list) + len(other._list))
        for i in range(len(self._list)):
            result.append(self._list[i])
        for i in range(len(other._list)):
            result.append(other._list[i])
        return result^

    @always_inline("nodebug")
    fn __add__(self, other: List[Int]) -> Self:
        var result = IntArray.with_capacity(len(self._list) + len(other))
        for i in range(len(self._list)):
            result.append(self._list[i])
        for i in range(len(other)):
            result.append(other[i])
        return result^

    @always_inline("nodebug")
    fn __radd__(self, other: List[Int]) -> Self:
        var result = IntArray.with_capacity(len(other) + len(self._list))
        for i in range(len(other)):
            result.append(other[i])
        for i in range(len(self._list)):
            result.append(self._list[i])
        return result^

    @always_inline("nodebug")
    fn pop(mut self, index: Int = -1) -> Int:
        """Remove and return element."""
        if len(self._list) < 1:
            panic("IntArray: cannot pop from empty array")
        var i = index if index >= 0 else index + len(self._list)
        if i < 0 or i >= len(self._list):
            panic("IntArray: pop index out of bounds")

        var val = self._list[i]
        # Shift left (manual implementation since we need exact behavior)
        for j in range(i, len(self._list) - 1):
            self._list[j] = self._list[j + 1]
        # Manually shrink the list
        var new_list = List[Int](capacity=self._list.capacity)
        for j in range(len(self._list) - 1):
            new_list.append(self._list[j])
        self._list = new_list^
        return val

    fn clear(mut self):
        """Clear all elements."""
        self._list = List[Int](capacity=self._list.capacity)

    # ========== Modification Operations ==========

    @always_inline("nodebug")
    fn replace(self, idx: Int, value: Int) -> Self:
        """Return copy with element at idx replaced."""
        var result = self.copy()
        result[idx] = value
        return result^

    @always_inline("nodebug")
    fn replace(self, indices: Self, values: Self) -> Self:
        """Return copy with multiple replacements."""
        var n = len(self._list)
        var m = len(indices)
        if m != len(values):
            panic("IntArray -> replace: indices and values must be same length")

        # Validate indices: no out-of-bounds, no duplicates
        for i in range(m):
            var idx = indices[i]
            if idx < 0 or idx >= n:
                panic("IntArray -> replace: index out of bounds: " + String(idx))

        var result = self.copy()
        # Apply replacements
        for i in range(m):
            result[indices[i]] = values[i]

        return result^

    @always_inline("nodebug")
    fn insert(self, at: Int, value: Int) -> Self:
        """Insert value at position, return new IntArray."""
        if at < 0 or at > len(self._list):
            panic("IntArray -> insert - index out of bounds: " + String(at))

        var result = IntArray.with_capacity(len(self._list) + 1)
        for i in range(len(self._list) + 1):
            if i == at:
                result.append(value)
            if i < len(self._list):
                result.append(self._list[i])
        return result^

    @always_inline("nodebug")
    fn insert(self, indices: Self, values: Self) -> Self:
        """Insert values at multiple sorted indices."""
        if len(indices) != len(values):
            panic("IntArray -> insert: indices and values must be same length")

        var n = len(self._list)
        var m = len(indices)

        if n == 0:
            if m == 0:
                return IntArray()
            # Ensure indices = [0, 1, ..., m-1]
            var is_valid = True
            for i in range(m):
                if indices[i] != i:
                    is_valid = False
                    break
            if not is_valid:
                panic("IntArray -> insert: invalid indices for empty array insertion")
            return values

        var final_size = n + m
        # Create dense result
        var result = IntArray.with_capacity(final_size)
        var red_cursor = 0
        var orig_cursor = 0

        for i in range(final_size):
            if red_cursor < m and indices[red_cursor] == i:
                result.append(values[red_cursor])
                red_cursor += 1
            else:
                if orig_cursor >= n:
                    panic("IntArray -> insert: ran out of source values too early")
                result.append(self._list[orig_cursor])
                orig_cursor += 1

        return result^

    # ========== Sorting ==========

    fn sort(mut self, asc: Bool = True):
        """Insertion sort in place."""
        for i in range(1, len(self._list)):
            var elem = self._list[i]
            var j = i
            while j > 0 and (elem < self._list[j - 1] if asc else elem > self._list[j - 1]):
                self._list[j] = self._list[j - 1]
                j -= 1
            self._list[j] = elem

    fn sorted(self, asc: Bool = True) -> Self:
        """Return sorted copy."""
        var result = self.copy()
        result.sort(asc)
        return result^

    # ========== Search Operations ==========

    @always_inline("nodebug")
    fn indices_of(self, val: Int) -> Self:
        """Return indices where value equals val."""
        var result = IntArray.with_capacity(min(4, len(self._list)))
        for i in range(len(self._list)):
            if self._list[i] == val:
                result.append(i)
        return result

    @always_inline("nodebug")
    fn fill(mut self, value: Int):
        """Fill with value."""
        for i in range(len(self._list)):
            self._list[i] = value

    @always_inline("nodebug")
    fn __contains__(self, value: Int) -> Bool:
        """Check if contains value."""
        for i in range(len(self._list)):
            if self._list[i] == value:
                return True
        return False

    # ========== Equality ==========

    fn __eq__(self, other: Self) -> Bool:
        """Check equality."""
        if len(self._list) != len(other._list):
            return False
        for i in range(len(self._list)):
            if self._list[i] != other._list[i]:
                return False
        return True

    fn __eq__(self, other: List[Int]) -> Bool:
        """Check equality with List."""
        if len(self._list) != len(other):
            return False
        for i in range(len(self._list)):
            if self._list[i] != other[i]:
                return False
        return True

    @always_inline("nodebug")
    fn __ne__(self, other: Self) -> Bool:
        return not (self == other)

    # ========== Conversions ==========

    @always_inline("nodebug")
    fn tolist(self) -> List[Int]:
        """Convert to List[Int]."""
        return self._list.copy()

    # ========== String Representation ==========

    @no_inline
    fn __str__(self) -> String:
        """String representation."""
        if len(self._list) == 0:
            return "[]"
        var result = String("[")
        for i in range(len(self._list)):
            if i > 0:
                result += ", "
            result += String(self._list[i])
        result += "]"
        return result

    @no_inline
    fn __repr__(self) -> String:
        return self.__str__()

    fn write_to[W: Writer](self, mut writer: W):
        writer.write(self.__str__())

    # ========== Math Operations ==========

    @always_inline("nodebug")
    fn product(self) -> Int:
        """Product of all elements."""
        if len(self._list) == 0:
            return 1
        var prod = 1
        for i in range(len(self._list)):
            prod *= self._list[i]
        return prod

    @always_inline("nodebug")
    fn sum(self) -> Int:
        """Sum of all elements."""
        var s = 0
        for i in range(len(self._list)):
            s += self._list[i]
        return s

    # ========== Functional Operations ==========

    @always_inline("nodebug")
    fn reverse(mut self):
        """Reverse in place."""
        for i in range(len(self._list) // 2):
            var temp = self._list[i]
            self._list[i] = self._list[len(self._list) - 1 - i]
            self._list[len(self._list) - 1 - i] = temp

    @always_inline("nodebug")
    fn reversed(self) -> Self:
        """Return reversed copy."""
        var result = IntArray.with_capacity(len(self._list))
        for i in range(len(self._list) - 1, -1, -1):
            result.append(self._list[i])
        return result^

    # ========== Iterators ==========

    @always_inline("nodebug")
    fn __iter__(ref self) -> IntArrayIterator[origin_of(self)]:
        """Iterate over elements."""
        return IntArrayIterator(0, Pointer(to=self))

    @always_inline("nodebug")
    fn __reversed__(ref self) -> IntArrayIterator[origin_of(self), False]:
        """Iterate backwards."""
        return IntArrayIterator[forward=False](len(self), Pointer(to=self))

    @always_inline("nodebug")
    fn zip(ref self, ref other: Self) -> ZipIterator[origin_of(self), origin_of(other)]:
        """Iterate over elements of two IntArrays."""
        return ZipIterator(0, Pointer(to=self), Pointer(to=other))

    @always_inline("nodebug")
    fn zip_reversed(
        ref self, ref other: Self
    ) -> ZipIterator[origin_of(self), origin_of(other), False]:
        """Iterate over element pairs in reverse order."""
        return ZipIterator[forward=False](
            min(len(self), len(other)), Pointer(to=self), Pointer(to=other)
        )

    # ========== Utility ==========

    @always_inline("nodebug")
    fn copy(self) -> Self:
        """Explicit copy method."""
        return Self(self._list)

# Iterator implementations remain exactly the same
@register_passable
struct IntArrayIterator[
    origin: ImmutOrigin,
    forward: Bool = True,
](Sized & Copyable):
    var index: Int
    var src: Pointer[IntArray, Self.origin]

    fn __init__(out self, idx: Int, src: Pointer[IntArray, Self.origin]):
        self.src = src
        self.index = idx

    @always_inline("nodebug")
    fn __copyinit__(out self, existing: Self):
        self.index = existing.index
        self.src = existing.src

    fn __iter__(self) -> Self:
        return self.copy()

    fn __next__(mut self) -> Int:
        @parameter
        if Self.forward:
            self.index += 1
            return self.src[][self.index - 1]
        else:
            self.index -= 1
            return self.src[][self.index]

    @always_inline
    fn __has_next__(self) -> Bool:
        return self.__len__() > 0

    fn __len__(self) -> Int:
        @parameter
        if Self.forward:
            return len(self.src[]) - self.index
        else:
            return self.index


struct ZipIterator[
    origin_this: ImmutOrigin,
    origin_that: ImmutOrigin,
    forward: Bool = True,
](Sized & Copyable):
    var index: Int
    var offset: Int
    var src_this: Pointer[IntArray, Self.origin_this]
    var src_that: Pointer[IntArray, Self.origin_that]

    fn __init__(
        out self,
        idx: Int,
        src_this: Pointer[IntArray, Self.origin_this],
        src_that: Pointer[IntArray, Self.origin_that],
    ):
        self.src_this = src_this
        self.src_that = src_that
        self.index = idx
        self.offset = abs(len(src_this[]) - len(src_that[]))

    @always_inline("nodebug")
    fn __copyinit__(out self, existing: Self):
        self.index = existing.index
        self.offset = existing.offset
        self.src_this = existing.src_this
        self.src_that = existing.src_that

    fn __iter__(self) -> Self:
        return self.copy()

    fn __next__(mut self) -> Tuple[Int, Int]:
        @parameter
        if Self.forward:
            self.index += 1
            return (
                self.src_this[][self.index - 1],
                self.src_that[][self.index - 1],
            )
        else:
            self.index -= 1
            if len(self.src_this[]) > len(self.src_that[]):
                return (
                    self.src_this[][self.index + self.offset],
                    self.src_that[][self.index],
                )
            else:
                return (
                    self.src_this[][self.index],
                    self.src_that[][self.index + self.offset],
                )

    @always_inline
    fn __has_next__(self) -> Bool:
        return self.__len__() > 0

    fn __len__(self) -> Int:
        @parameter
        if Self.forward:
            return min(len(self.src_this[]), len(self.src_that[])) - self.index
        else:
            return self.index

fn main():
    pass
