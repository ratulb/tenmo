        var c1 = t.contiguous()
        var c2 = c1.contiguous()
        assert_true(
            c2.to_cpu().all_close(Tensor[dtype].d2([[1.0, 3.0], [2.0, 4.0]]))
        )
        var loss = c2.sum()
        loss.backward()
        assert_true(a.grad().all_close(Tensor.ones_like(a)))



