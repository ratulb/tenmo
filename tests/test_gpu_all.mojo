        assert_true(result[[3]] == True)



def test_compare_gpu_gt_1d() raises:
    comptime if has_accelerator():
        comptime dtype = DType.float32
        var a = Tensor[dtype].d1([1.0, 5.0, 3.0]).to_gpu()
