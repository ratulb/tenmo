        loss.backward()
        assert_true(
            b.grad()
            .to_cpu()
            .all_close[atol=1e-5](Tensor[dtype].full_like(a, 45.0))
        )
        assert_true(a.grad().all_close[atol=1e-5](Tensor.zeros_like(a)))



