def test_sqrt_bwd_gpu_chain_mul() raises:
    comptime if has_accelerator():
        comptime dtype = DType.float32
        var a_cpu = Tensor[dtype].d1([1.0, 4.0, 9.0], requires_grad=True)
        var a_gpu = a_cpu.to_gpu()
