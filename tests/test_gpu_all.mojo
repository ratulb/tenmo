        a_copy.requires_grad_(True)
        var a_gpu = a.to_gpu()
        var s_gpu = a_gpu.sum(axes=[0], keepdims=True)
        var s_cpu_ref = a_copy.sum(axes=[0], keepdims=True)
        assert_true(s_gpu.to_cpu().all_close(s_cpu_ref))
        ss = s_gpu.to_cpu().sum()
        ss.backward()
        sss = s_cpu_ref.sum()
        sss.backward()
        assert_true(a.grad().all_close(a_copy.grad()))



