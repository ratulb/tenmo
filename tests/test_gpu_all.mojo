        comptime dtype = DType.float32
        # All ones — product=1, exercises multi-block dispatch
        var a = Tensor[dtype].full([65536], 1.0).to_gpu()
        var out = a.product(IntArray(0))
        assert_true(
            out.to_cpu().all_close[atol=1e-3](Tensor[dtype].scalar(1.0))
        )



