def test_rlv_gpu_fwd_mixed() raises:
    comptime if has_accelerator():
        print("test_rlv_gpu_fwd_mixed")
        comptime dtype = DType.float32
        var a = Tensor[dtype].d1([-3.0, 0.0, 2.0, -1.0, 5.0]).to_gpu()
        var out = a.relu()
        assert_true(
