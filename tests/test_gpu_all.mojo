        var a_gpu = a.to_gpu()
        var c = a_gpu.contiguous()
        assert_true(c.to_cpu().all_close(Tensor[dtype].d1([10.0, 20.0, 30.0])))
        var loss = c.sum()
        loss.backward()
        assert_true(a.grad().all_close(Tensor.ones_like(a)))



